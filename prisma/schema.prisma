generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CooperativeStatus {
  ACTIVE
  PAST_DUE
  CANCELED
}

enum UserRole {
  MEMBER
  ADMIN
  TREASURER
  OWNER
}

enum LoanStatus {
  PENDING_GUARANTORS
  PENDING_ADMIN_REVIEW
  APPROVED
  REJECTED
  REPAID
}

enum GuarantorStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ContributionStatus {
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
}

enum PaymentMethod {
  BANK_TRANSFER
  MOBILE_MONEY
  CASH
  DIRECT_PAYMENT
}

model Cooperative {
  id                   String            @id @default(cuid())
  name                 String
  stripeCustomerId     String?           @unique
  stripeSubscriptionId String?
  subscriptionStatus   CooperativeStatus @default(ACTIVE)
  billingCycleEnd      DateTime?
  borrowingMultiplier    Int               @default(3)
  guarantorCoverageMode  String            @default("COMBINED")
  loanInterestRate       Decimal           @default(10)
  loanRepaymentMonths    Int               @default(12)
  defaultGracePeriodDays Int               @default(30)
  currency               String            @default("NGN")
  currencySymbol         String            @default("₦")
  deletedAt              DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  users              User[]
  contributions      Contribution[]
  loans              LoanApplication[]
  events             Event[]
  bankAccounts       CooperativeBank[]
  notifications      Notification[]
  dividendPayouts    DividendPayout[]
  withdrawalRequests WithdrawalRequest[]
  announcements      Announcement[]
}

model Account {
  id           String    @id @default(cuid())
  accountId    String
  providerId   String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String?
  refreshToken String?
  idToken      String?
  expiresAt    DateTime?
  password     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?

  @@index([userId])
  @@map("session")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@unique([identifier, value])
  @@index([identifier])
  @@map("verification")
}

model User {
  id                        String      @id @default(cuid())
  cooperativeId             String
  cooperative               Cooperative @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  email                     String      @unique
  emailVerified             Boolean     @default(false)
  name                      String
  image                     String?
  passwordHash              String?
  role                      UserRole    @default(MEMBER)
  monthlyContributionAmount String      @default("0")
  verifiedAt                DateTime?
  verifiedBy                String?
  invitedAt                 DateTime?
  joinedAt                  DateTime?
  deletedAt                 DateTime?
  phoneNumber               String?
  emailNotifications        Boolean     @default(true)
  smsNotifications          Boolean     @default(true)
  createdAt                 DateTime    @default(now())
  updatedAt                 DateTime    @updatedAt

  accounts              Account[]
  sessions              Session[]
  loanApplications      LoanApplication[]
  guarantorFor          LoanGuarantor[]    @relation("guarantor")
  approvalsGiven        LoanApplication[]  @relation("approvedBy")
  verificationsGiven    Contribution[]     @relation("verifiedBy")
  contributions         Contribution[]
  withdrawalRequests    WithdrawalRequest[]
  createdAnnouncements  Announcement[]     @relation("AnnouncementCreator")
  announcementRsvps     AnnouncementRsvp[]

  @@map("user")
}

model LoanApplication {
  id              String      @id @default(cuid())
  cooperativeId   String
  cooperative     Cooperative @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  userId          String
  applicant       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountRequested Decimal
  status          LoanStatus  @default(PENDING_GUARANTORS)
  appliedAt       DateTime    @default(now())

  guarantors LoanGuarantor[]
  repayments LoanRepayment[]

  interestRate    Decimal?
  repaymentMonths Int?
  totalAmountDue  Decimal?
  approvedAt      DateTime?
  repaidAt        DateTime?
  reviewedBy      String?
  reviewer        User?     @relation("approvedBy", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?
  rejectionReason String?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([cooperativeId])
  @@index([userId])
  @@index([status])
}

model LoanGuarantor {
  id              String          @id @default(cuid())
  loanId          String
  loan            LoanApplication @relation(fields: [loanId], references: [id], onDelete: Cascade)
  guarantorId     String
  guarantor       User            @relation("guarantor", fields: [guarantorId], references: [id], onDelete: Cascade)
  status          GuarantorStatus @default(PENDING)
  acceptedAt      DateTime?
  rejectionReason String?
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([loanId, guarantorId])
  @@index([guarantorId])
}

model Contribution {
  id               String             @id @default(cuid())
  cooperativeId    String
  cooperative      Cooperative        @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  userId           String
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount           Decimal
  status           ContributionStatus @default(PENDING_VERIFICATION)
  paymentMethod    PaymentMethod
  receiptUrl          String?
  receiptKey          String?   // S3 object key (set when file is uploaded)
  receiptFileName     String?
  receiptFileSize     Int?
  receiptFileType     String?
  receiptUploadedAt   DateTime?
  rejectionCount      Int       @default(0)
  submittedAt         DateTime  @default(now())
  verifiedByUserId String?
  verifiedBy       User?              @relation("verifiedBy", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  verifiedAt       DateTime?
  rejectionReason  String?
  deletedAt        DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([cooperativeId])
  @@index([userId])
  @@index([status])
}

model Event {
  id            String      @id @default(cuid())
  cooperativeId String
  cooperative   Cooperative @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  eventType     String
  actorId       String?
  actorType     String?
  entityType    String?
  entityId      Int?
  data          Json
  deletedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([cooperativeId, createdAt])
  @@index([eventType])
}

model LoanRepayment {
  id          String          @id @default(cuid())
  loanId      String
  loan        LoanApplication @relation(fields: [loanId], references: [id], onDelete: Cascade)
  amount      Decimal
  paymentType String
  paidAt      DateTime
  receiptUrl  String?
  recordedBy  String?
  note        String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([loanId])
}

model CooperativeBank {
  id            String      @id @default(cuid())
  cooperativeId String
  cooperative   Cooperative @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  accountName   String
  accountNumber String
  bankName      String
  isPreferred   Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([cooperativeId])
}

model Notification {
  id            String      @id @default(cuid())
  cooperativeId String
  cooperative   Cooperative @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  userId        String
  type          String
  channel       String
  recipient     String
  subject       String?
  body          String
  status        String      @default("SENT")
  externalId    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([cooperativeId])
  @@index([userId])
  @@index([createdAt])
}

model DividendPayout {
  id              String           @id @default(cuid())
  cooperativeId   String
  cooperative     Cooperative      @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  period          String
  year            Int
  totalProfit     Decimal
  adminCosts      Decimal
  loanLossReserve Decimal
  dividendPool    Decimal
  totalMembers    Int
  status          String           @default("PENDING")
  approvedAt      DateTime?
  approvedBy      String?
  paidAt          DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  memberDividends MemberDividend[]

  @@index([cooperativeId])
}

model MemberDividend {
  id              String         @id @default(cuid())
  payoutId        String
  payout          DividendPayout @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  userId          String
  cooperativeId   String
  contributionPct Decimal
  amount          Decimal
  status          String         @default("PENDING")
  paidAt          DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([payoutId])
  @@index([userId])
  @@index([cooperativeId])
}

model WithdrawalRequest {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  cooperativeId String
  cooperative   Cooperative @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)

  amount          Decimal
  reason          String
  notes           String?
  status          String    @default("REQUESTED")
  rejectionReason String?

  approvedAt DateTime?
  approvedBy String?
  paidAt     DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([cooperativeId])
  @@index([status])
}

model Announcement {
  id            String      @id @default(cuid())
  cooperativeId String
  cooperative   Cooperative @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)

  title         String
  message       String
  type          String      // AGM | MAINTENANCE | RULE_CHANGE | GENERAL

  recipientType String      @default("ALL") // ALL | MEMBERS_ONLY | ADMINS_ONLY | SPECIFIC_ROLE
  recipientRole String?

  agmDate       DateTime?
  agmLocation   String?
  allowRsvp     Boolean     @default(false)

  isPinned      Boolean     @default(true)
  isActive      Boolean     @default(true)
  expiresAt     DateTime?

  createdBy     String
  creator       User        @relation("AnnouncementCreator", fields: [createdBy], references: [id])

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  rsvps         AnnouncementRsvp[]

  @@index([cooperativeId])
  @@index([isActive, isPinned])
}

model AnnouncementRsvp {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  rsvpStatus     String       // ATTENDING | NOT_ATTENDING | MAYBE
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([announcementId, userId])
  @@index([announcementId])
}
